# Postgres
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading

# Redis
REDIS_URL=redis://localhost:6379/0

# Alerting — Slack
SLACK_WEBHOOK_URL=

# Alerting — Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Heartbeat / monitoring
HEARTBEAT_STALE_SECONDS=15
HEARTBEAT_POLL_SECONDS=5
HEARTBEAT_REPEAT_SUPPRESS_SECONDS=60

# UI refresh cadence
SSE_TICK_SECONDS=1

# App
APP_HOST=0.0.0.0
APP_PORT=8787
LOG_LEVEL=INFO
