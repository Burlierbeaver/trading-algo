# Alpaca
ALPACA_MODE=paper                        # paper | live
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Postgres
DATABASE_URL=postgresql://localhost:5432/trading_algo

# Execution tuning
POLL_INTERVAL_S=1.0
POLL_TIMEOUT_S=30.0

# Live safety rails (unset = disabled)
MAX_NOTIONAL_PER_ORDER=
MAX_QTY_PER_ORDER=
SYMBOL_WHITELIST=                        # comma-separated, e.g. SPY,QQQ,AAPL
KILL_SWITCH_FILE=                        # path; if file exists, live orders rejected
