{
  "name": "@trading-algo/strategy-engine",
  "version": "0.1.0",
  "description": "Strategy engine — maps Signal + MarketData to TradeIntent. The swappable alpha layer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
